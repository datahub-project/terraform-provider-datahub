# Copy this file to terraform.tfvars and uncomment the variables you want to override.
# terraform.tfvars is gitignored and will not be committed.

# Email address for the new team member created by this example.
# Used as both the username and email field.
#
# Email format works on both OSS and Cloud:
#   OSS:   any string is valid as a username; email format is accepted.
#   Cloud: the URN is always derived from the email field, so username must
#          equal email. This is already satisfied when you use an email address.
#
# Use a real email address if you want to send the password reset link to
# an actual person. Retrieve the link after apply:
#   terraform output -raw team_member_reset_url
#
# Note: terraform destroy hard-deletes the user entity (not just credentials).
#
# new_member_email = "alice@example.com"

# Username of an existing DataHub user to also add to the group.
# Must already exist (provisioned via SSO/JIT or separately).
# Defaults to "datahub" (the bootstrap admin on an OSS Quickstart).
#
# member_username = "datahub"
